{
    "version": 2,
    "builds": [
        {
            "src": "src/main.ts",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "src/main.ts"
        }
    ],
    "redirects": [
    {
      "source": "/",
      "destination": "https://github.com/JessicaKei/github-readme-activity-graph"
    }
  ]
}
